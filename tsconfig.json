{
	"compilerOptions": {
		"module": "node16",
		"declaration": true,
		"target": "es2019",
		"rootDir": "./lib",
		"outDir": "build",
		"noImplicitAny": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"removeComments": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"preserveSymlinks": true
	},
	"include": [
		"./lib/**/*",
		"./bin/**/*"
	]
}
